{
  "name": "test-evals",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.5",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:web": "turbo -F web build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @test-evals/db db:push",
    "db:studio": "turbo -F @test-evals/db db:studio",
    "db:generate": "turbo -F @test-evals/db db:generate",
    "db:migrate": "turbo -F @test-evals/db db:migrate",
    "test:bedrock": "bun run scripts/test-bedrock.ts",
    "eval": "bun run scripts/eval.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1039.0",
    "@smithy/node-http-handler": "^4.6.1",
    "@test-evals/env": "workspace:*",
    "@test-evals/shared": "workspace:*",
    "@test-evals/llm": "workspace:*",
    "dotenv": "catalog:",
    "fuzzball": "^2.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@test-evals/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
