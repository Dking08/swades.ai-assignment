# ==============================================
# HEALOSBENCH Server Environment Configuration
# ==============================================

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/healosbench

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-chars-long!!
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# ==============================================
# LLM Provider Configuration
# Set at least ONE provider's API key.
# Priority: ANTHROPIC_API_KEY > AWS_BEARER_TOKEN_BEDROCK > GEMINI_API_KEY
# ==============================================

# --- Option A: Anthropic Direct API (highest priority) ---
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL_ID=claude-haiku-4-5-20251001

# --- Option B: Amazon Bedrock ---
#AWS_BEARER_TOKEN_BEDROCK=VALUE
#AWS_REGION=ap-south-1
#BEDROCK_MODEL_ID=claude-haiku-4-5-20251001

# --- Option C: Google Gemini ---
# GEMINI_API_KEY=VALUE
# GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview

# --- Environment ---
NODE_ENV=development
